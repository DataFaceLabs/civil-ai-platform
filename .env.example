# Civil AI Platform — local development
CIVILAI_ENVIRONMENT=dev
CIVILAI_DEV_AUTH=true
CIVILAI_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Ephemeral — data lost when API restarts
# CIVILAI_STORE_BACKEND=memory
# CIVILAI_ARTIFACT_BACKEND=memory

# Durable persistence — AWS DynamoDB + S3 (requires AWS_PROFILE with DynamoDB + S3 access)
CIVILAI_STORE_BACKEND=dynamodb
CIVILAI_DYNAMODB_TABLE=civilai-app-dev
CIVILAI_ARTIFACT_BACKEND=s3
CIVILAI_APP_BUCKET=civilai-data
AWS_PROFILE=civilai
AWS_REGION=us-east-1

# Optional: DynamoDB Local via Docker instead of AWS
# CIVILAI_DYNAMODB_ENDPOINT_URL=http://localhost:8002

# Alternative: file store (no AWS)
# CIVILAI_STORE_BACKEND=file
# CIVILAI_FILE_STORE_PATH=.local/platform-store

# AWS production / Lambda
# CIVILAI_COGNITO_USER_POOL_ID=
# CIVILAI_COGNITO_APP_CLIENT_ID=
# CIVILAI_DEV_AUTH=false

# Data API proxy (Pillar F — must match civil-ai-data CIVILAI_DATA_SERVICE_KEY)
CIVILAI_DATA_API_BASE=http://localhost:8000
# CIVILAI_DATA_SERVICE_KEY=dev-platform-service-key
# LLM invoke proxy timeout (default 180s; standard data-proxy calls stay at 30s)
# CIVILAI_DATA_LLM_INVOKE_TIMEOUT_SEC=180

# Agent runs (Strands via civilai-agent; dry-run avoids Bedrock in local dev)
CIVILAI_AGENT_DRY_RUN=true

