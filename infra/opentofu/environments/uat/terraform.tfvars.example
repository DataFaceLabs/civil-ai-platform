# Copy to terraform.tfvars (never commit secrets).

aws_region = "us-east-1"

# REQUIRED — your public IP for SSH
allowed_ssh_cidr_blocks = ["YOUR.PUBLIC.IP/32"]

# Start permissive for UAT smoke; tighten before external testers
allowed_api_cidr_blocks = ["0.0.0.0/0"]

# Prod container (port 8000): MUST track s3://civilai-data/prod/serving/current.json.
# A replaced instance boots from this URI (entrypoint only fetches when /data is empty).
serving_s3_uri = "s3://civilai-data/prod/serving/snapshot_date=2026-07-15e/civil_ai_serving.duckdb"

# Dev container (port 8001): DuckDB-over-S3 via the published pointer. Empty = no
# second container. Pointer form means a fresh publish is visible without redeploy.
dev_serving_s3_uri = "s3://civilai-data/dev/serving/current.json"

mapbox_access_token = "pk...."

# Browser Origin allow-list for data-API CORS *and* S3 presigned uploads.
cors_origins = [
  "http://localhost:5173",
  "http://localhost:3000",
  "http://localhost:8080",
  "http://127.0.0.1:5173",
  "http://127.0.0.1:3000",
  "https://www.civil1.ai",
  "https://civil1.ai",
  # Optional Amplify default domain while custom DNS is settling:
  # "https://develop.d3joxyeudajkza.amplifyapp.com",
]

# Add Amplify default domain after first apply, e.g. https://develop.d1234.amplifyapp.com/fstudio/*/login/callback
cognito_callback_urls = [
  "http://localhost:5173/fstudio/*/login/callback",
]
cognito_logout_urls = [
  "http://localhost:5173/fstudio/*/login",
]

# GitHub PAT (repo scope) for Amplify + optional EC2 clone
github_access_token = "ghp_..."

# Optional: store PAT in SSM first, then set name here for EC2 user_data
# aws ssm put-parameter --name /civilai/uat/github-token --type SecureString --value ghp_...
# github_token_parameter_name = "/civilai/uat/github-token"

create_platform_http_api = true
create_amplify_app       = true

# Production Amplify branch (civil1.ai). Defaults to "main" post release-migration;
# leaving it out is fine, but NEVER set it to "" on an environment where the branch
# is live — that plans a destroy of the production frontend.
fe_production_branch_name = "main"

# Run ../../scripts/package-lambda.sh before apply when create_platform_http_api=true.
# NOTE: initial creation only. Lambda CODE deploys go through scripts/deploy-lambda.sh;
# tofu ignores source_code_hash so a stale local zip can't roll back the live API.
lambda_package_path = "../../../dist/platform-lambda.zip"
